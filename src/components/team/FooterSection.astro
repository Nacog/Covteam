---
import { footerGroups } from '../../data/covteam';
---

<footer class="site-footer" id="footer">
	<div class="footer-shell">
		<div class="footer-intro">
			<p class="footer-kicker">Covteam Resources</p>
			<h2>继续探索这个团队</h2>
			<p>已经到底啦</p>
		</div>

		<div class="footer-grid">
			{
				footerGroups.map((group) => (
					<section class="footer-group" aria-label={group.title}>
						<h3>{group.title}</h3>
						{
							group.links.length > 0 ? (
								<ul>
									{group.links.map((link) => (
										<li>
											<a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>
												{link.label}
											</a>
										</li>
									))}
								</ul>
							) : (
								<p class="footer-empty">No items yet.</p>
							)
						}
					</section>
				))
			}
		</div>

		<div class="footer-meta">
			<span>Covteam Team Page</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		z-index: 1;
		padding: 88px 24px 48px;
	}

	.footer-shell {
		max-width: 1200px;
		margin: 0 auto;
		padding: 32px 0 0;
		border-top: 1px solid rgba(241, 224, 186, 0.14);
	}

	.footer-intro {
		max-width: 640px;
		margin-bottom: 28px;
	}

	.footer-kicker {
		margin: 0 0 12px;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-size: 0.78rem;
		color: #66d6b5;
	}

	.footer-intro h2 {
		margin: 0;
		font-size: clamp(1.8rem, 4vw, 2.6rem);
	}

	.footer-intro p {
		margin: 14px 0 0;
		line-height: 1.75;
		color: rgba(246, 242, 232, 0.72);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 32px;
		padding-top: 24px;
		border-top: 1px solid rgba(241, 224, 186, 0.08);
	}

	.footer-group h3 {
		margin: 0 0 16px;
		font-size: 1rem;
		color: #f2b35d;
	}

	.footer-group ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-group li + li {
		margin-top: 10px;
	}

	.footer-group a {
		display: inline-flex;
		align-items: center;
		padding: 6px 0;
		text-decoration: none;
		color: rgba(246, 242, 232, 0.88);
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.footer-group a:hover {
		transform: translateX(3px);
		color: #fff8ee;
	}

	.footer-empty {
		margin: 0;
		padding: 6px 0;
		color: rgba(246, 242, 232, 0.42);
	}

	.footer-meta {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 12px;
		margin-top: 28px;
		padding-top: 18px;
		border-top: 1px solid rgba(241, 224, 186, 0.08);
		font-size: 0.92rem;
		color: rgba(246, 242, 232, 0.56);
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 24px;
		}
	}

	@media (max-width: 820px) {
		.site-footer {
			padding-inline: 16px;
			padding-top: 72px;
		}

		.footer-shell {
			padding-top: 24px;
		}
	}
</style>
