---
interface StatItem {
	label: string;
	value: string;
}

interface Props {
	stats: StatItem[];
}

const { stats } = Astro.props;
---

<section class="hero">
	<div class="hero-copy">
		<p class="eyebrow">H4ck 4 fun!</p>
		<h1>Covteam</h1>
		<p class="lead">
			聚焦 Web、安全研发、二进制与基础设施能力建设，延续 CTF 与实战并重的学习传统，
			也欢迎对网络安全、开发与技术社区有热情的同学加入我们。
		</p>

		<div class="hero-actions">
			<a class="button primary" href="#member">查看成员</a>
			<a class="button secondary" href="#lookfor">了解招新</a>
		</div>

		<div class="stats" aria-label="团队概况">
			{
				stats.map((item) => (
					<div class="stat-card">
						<strong>{item.value}</strong>
						<span>{item.label}</span>
					</div>
				))
			}
		</div>
	</div>

	<div class="hero-visual">
		<div class="visual-panel logo-panel">
			<img src="/img/Covteam_logo1.png" alt="Covteam Logo" />
		</div>
		<div class="visual-panel photo-panel">
			<img src="/img/Covteam-hack.jpg" alt="Covteam 团队活动" />
		</div>
	</div>
</section>
