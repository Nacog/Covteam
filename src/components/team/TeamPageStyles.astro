<style is:global>
	main {
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(circle at top left, rgba(43, 108, 176, 0.3), transparent 28%),
			radial-gradient(circle at 85% 10%, rgba(13, 148, 136, 0.18), transparent 24%),
			linear-gradient(180deg, #08111f 0%, #0c1728 40%, #09111d 100%);
	}

	main::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
		background-size: 32px 32px;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.45), transparent 95%);
		pointer-events: none;
	}

	section {
		position: relative;
		z-index: 1;
	}

	.hero,
	.section {
		max-width: 1200px;
		margin: 0 auto;
		padding-inline: 24px;
	}

	.hero {
		min-height: calc(100vh - 80px);
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
		align-items: center;
		gap: 36px;
		padding-top: 48px;
		padding-bottom: 40px;
	}

	.eyebrow,
	.section-kicker {
		margin: 0 0 14px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.8rem;
		color: #7dd3fc;
	}

	h1 {
		margin: 0;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.95;
		letter-spacing: -0.05em;
		max-width: 10ch;
	}

	.lead,
	.section-heading p,
	.info-card p,
	.member-body p,
	.achievement-item p {
		color: rgba(230, 237, 247, 0.74);
		line-height: 1.75;
	}

	.lead {
		max-width: 620px;
		margin: 22px 0 0;
		font-size: 1.05rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 28px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0 20px;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	.button:hover {
		transform: translateY(-2px);
	}

	.button.primary {
		background: linear-gradient(135deg, #38bdf8, #0ea5e9);
		color: #04111c;
		box-shadow: 0 16px 40px rgba(14, 165, 233, 0.28);
	}

	.button.secondary {
		border: 1px solid rgba(125, 211, 252, 0.28);
		background: rgba(255, 255, 255, 0.03);
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 14px;
		margin-top: 34px;
	}

	.stat-card,
	.info-card,
	.member-card,
	.visual-panel,
	.achievement-item {
		border: 1px solid rgba(148, 163, 184, 0.16);
		background: rgba(11, 20, 35, 0.78);
		box-shadow: 0 18px 50px rgba(0, 0, 0, 0.22);
	}

	.stat-card {
		padding: 18px;
		border-radius: 20px;
	}

	.stat-card strong {
		display: block;
		font-size: 1.8rem;
		color: #f8fbff;
	}

	.stat-card span {
		display: block;
		margin-top: 6px;
		color: rgba(230, 237, 247, 0.7);
		font-size: 0.92rem;
	}

	.hero-visual {
		display: grid;
		gap: 18px;
	}

	.visual-panel {
		border-radius: 28px;
		overflow: hidden;
	}

	.logo-panel {
		padding: 42px;
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			radial-gradient(circle at top, rgba(56, 189, 248, 0.35), transparent 52%),
			linear-gradient(180deg, rgba(8, 145, 178, 0.12), rgba(8, 17, 31, 0.92));
	}

	.logo-panel img {
		width: min(100%, 240px);
		object-fit: contain;
	}

	.photo-panel {
		aspect-ratio: 4 / 3;
	}

	.photo-panel img,
	.member-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.section {
		padding-top: 80px;
		padding-bottom: 8px;
	}

	.section:last-child {
		padding-bottom: 96px;
	}

	.section-heading {
		max-width: 680px;
		margin-bottom: 28px;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		margin: 0;
	}

	h3 {
		margin: 0;
		font-size: 1.2rem;
	}

	.card-grid,
	.member-grid,
	.recruitment-grid {
		display: grid;
		gap: 18px;
	}

	.direction-grid,
	.recruitment-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.info-card {
		padding: 24px;
		border-radius: 24px;
	}

	.info-card ul {
		margin: 18px 0 0;
		padding-left: 18px;
		color: rgba(230, 237, 247, 0.82);
		line-height: 1.8;
	}

	.section-highlight {
		padding-top: 92px;
	}

	.achievement-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.achievement-item {
		display: flex;
		gap: 14px;
		padding: 18px 20px;
		border-radius: 20px;
		align-items: flex-start;
	}

	.achievement-item p {
		margin: 0;
	}

	.achievement-dot {
		width: 10px;
		height: 10px;
		margin-top: 10px;
		border-radius: 50%;
		flex: none;
		background: linear-gradient(135deg, #38bdf8, #22c55e);
		box-shadow: 0 0 0 6px rgba(56, 189, 248, 0.12);
	}

	.member-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.retired-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.member-card {
		border-radius: 24px;
		overflow: hidden;
	}

	.member-card.active {
		background:
			linear-gradient(180deg, rgba(14, 165, 233, 0.1), rgba(11, 20, 35, 0.92)),
			rgba(11, 20, 35, 0.78);
	}

	.member-card img {
		aspect-ratio: 1 / 1;
		max-height: 320px;
	}

	.member-body {
		padding: 18px;
	}

	.member-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 14px;
	}

	.member-meta span {
		padding: 6px 10px;
		border-radius: 999px;
		font-size: 0.82rem;
		color: #7dd3fc;
		background: rgba(56, 189, 248, 0.12);
	}

	.member-body p {
		margin: 0 0 16px;
		font-size: 0.95rem;
	}

	.member-body a,
	.member-link {
		font-size: 0.95rem;
		text-decoration: none;
		color: #7dd3fc;
	}

	.member-link.muted {
		color: rgba(230, 237, 247, 0.45);
	}

	@media (max-width: 1100px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.retired-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 820px) {
		.hero,
		.section {
			padding-inline: 16px;
		}

		.stats,
		.direction-grid,
		.achievement-list,
		.member-grid,
		.retired-grid,
		.recruitment-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
			padding-top: 28px;
			padding-bottom: 24px;
		}

		h1 {
			max-width: none;
		}

		.member-card img {
			max-height: 260px;
		}
	}
</style>
