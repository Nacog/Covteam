<style is:global>
	:root {
		--page-bg: #071412;
		--page-bg-deep: #020807;
		--surface: rgba(10, 28, 24, 0.8);
		--surface-strong: rgba(14, 37, 32, 0.92);
		--surface-soft: rgba(241, 224, 186, 0.08);
		--border: rgba(241, 224, 186, 0.14);
		--border-strong: rgba(241, 224, 186, 0.24);
		--text-main: #f6f2e8;
		--text-muted: rgba(246, 242, 232, 0.74);
		--text-soft: rgba(246, 242, 232, 0.56);
		--accent: #f2b35d;
		--accent-strong: #d97b2b;
		--accent-cool: #66d6b5;
		--shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
	}

	main {
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(circle at top left, rgba(242, 179, 93, 0.2), transparent 26%),
			radial-gradient(circle at 85% 12%, rgba(102, 214, 181, 0.18), transparent 24%),
			radial-gradient(circle at 50% 100%, rgba(217, 123, 43, 0.12), transparent 30%),
			linear-gradient(180deg, var(--page-bg) 0%, #0a1916 42%, var(--page-bg-deep) 100%);
		color: var(--text-main);
	}

	main::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
		background-size: 40px 40px;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.6), transparent 96%);
		pointer-events: none;
	}

	main::after {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(120deg, rgba(242, 179, 93, 0.06), transparent 34%),
			linear-gradient(300deg, rgba(102, 214, 181, 0.05), transparent 30%);
		pointer-events: none;
	}

	section {
		position: relative;
		z-index: 1;
	}

	.hero,
	.section {
		max-width: 1200px;
		margin: 0 auto;
		padding-inline: 24px;
	}

	.hero {
		min-height: calc(100vh - 80px);
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
		align-items: center;
		gap: 36px;
		padding-top: 48px;
		padding-bottom: 40px;
	}

	.eyebrow,
	.section-kicker {
		margin: 0 0 14px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.8rem;
		color: var(--accent-cool);
	}

	h1 {
		margin: 0;
		font-size: clamp(3rem, 8vw, 5.8rem);
		line-height: 0.95;
		letter-spacing: -0.05em;
		max-width: 10ch;
	}

	.lead,
	.section-heading p,
	.info-card p,
	.member-body p,
	.achievement-item p {
		color: var(--text-muted);
		line-height: 1.75;
	}

	.lead {
		max-width: 620px;
		margin: 22px 0 0;
		font-size: 1.05rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 28px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0 20px;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		color: var(--text-main);
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease,
			border-color 0.2s ease;
	}

	.button:hover {
		transform: translateY(-2px);
	}

	.button.primary {
		background: linear-gradient(135deg, var(--accent), var(--accent-strong));
		color: #1d1306;
		box-shadow: 0 16px 40px rgba(217, 123, 43, 0.28);
	}

	.button.secondary {
		border: 1px solid var(--border-strong);
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(10px);
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 14px;
		margin-top: 34px;
	}

	.stat-card,
	.info-card,
	.member-card,
	.visual-panel,
	.achievement-item {
		border: 1px solid var(--border);
		background: var(--surface);
		box-shadow: var(--shadow);
		backdrop-filter: blur(14px);
	}

	.stat-card {
		padding: 18px;
		border-radius: 22px;
		background:
			linear-gradient(180deg, rgba(242, 179, 93, 0.08), transparent 120px),
			var(--surface);
	}

	.stat-card strong {
		display: block;
		font-size: 1.8rem;
		color: var(--text-main);
	}

	.stat-card span {
		display: block;
		margin-top: 6px;
		color: var(--text-muted);
		font-size: 0.92rem;
	}

	.hero-visual {
		display: grid;
		gap: 18px;
	}

	.visual-panel {
		border-radius: 28px;
		overflow: hidden;
	}

	.logo-panel {
		padding: 42px;
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			radial-gradient(circle at top, rgba(242, 179, 93, 0.26), transparent 52%),
			linear-gradient(180deg, rgba(102, 214, 181, 0.1), rgba(7, 20, 18, 0.94));
	}

	.logo-panel img {
		width: min(100%, 240px);
		object-fit: contain;
	}

	.photo-panel {
		aspect-ratio: 4 / 3;
	}

	.photo-panel img,
	.member-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.section {
		padding-top: 80px;
		padding-bottom: 8px;
	}

	.section:last-child {
		padding-bottom: 96px;
	}

	.section-heading {
		max-width: 680px;
		margin-bottom: 28px;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		margin: 0;
	}

	h3 {
		margin: 0;
		font-size: 1.2rem;
	}

	.card-grid,
	.member-grid,
	.recruitment-grid {
		display: grid;
		gap: 18px;
	}

	.direction-grid,
	.recruitment-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.info-card {
		padding: 24px;
		border-radius: 24px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 100px),
			var(--surface);
	}

	.info-card ul {
		margin: 18px 0 0;
		padding-left: 18px;
		color: rgba(246, 242, 232, 0.82);
		line-height: 1.8;
	}

	.section-highlight {
		padding-top: 92px;
	}

	.achievement-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.achievement-item {
		display: flex;
		gap: 14px;
		padding: 18px 20px;
		border-radius: 20px;
		align-items: flex-start;
		background:
			linear-gradient(90deg, rgba(102, 214, 181, 0.08), transparent 45%),
			var(--surface);
	}

	.achievement-item p {
		margin: 0;
	}

	.achievement-dot {
		width: 10px;
		height: 10px;
		margin-top: 10px;
		border-radius: 50%;
		flex: none;
		background: linear-gradient(135deg, var(--accent), var(--accent-cool));
		box-shadow: 0 0 0 6px rgba(242, 179, 93, 0.12);
	}

	.member-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.member-card {
		display: flex;
		flex-direction: column;
		border-radius: 24px;
		overflow: hidden;
		background:
			linear-gradient(180deg, rgba(242, 179, 93, 0.08), transparent 120px),
			var(--surface-strong);
	}

	.member-card img {
		aspect-ratio: 1 / 1;
		max-height: 320px;
	}

	.member-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 18px;
	}

	.member-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 14px;
	}

	.member-meta h3 {
		color: var(--text-main);
	}

	.member-meta span {
		padding: 6px 10px;
		border-radius: 999px;
		font-size: 0.82rem;
		color: #10261f;
		background: linear-gradient(135deg, var(--accent-cool), #a9efd4);
	}

	.member-body p {
		margin: 0 0 16px;
		font-size: 0.95rem;
	}

	.member-footer {
		margin-top: auto;
		padding-top: 4px;
	}

	.member-body a,
	.member-link {
		font-size: 0.95rem;
		text-decoration: none;
		color: var(--accent);
	}

	.member-link.muted {
		color: var(--text-soft);
	}

	@media (max-width: 1100px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.member-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 820px) {
		.hero,
		.section {
			padding-inline: 16px;
		}

		.stats,
		.direction-grid,
		.achievement-list,
		.member-grid,
		.recruitment-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
			padding-top: 28px;
			padding-bottom: 24px;
		}

		h1 {
			max-width: none;
		}

		.member-card img {
			max-height: 260px;
		}
	}
</style>
