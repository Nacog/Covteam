---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Covteam 网络安全实验室',
	description = 'Covteam 团队主页，展示实验室方向、成绩、成员与招新信息。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: light;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		scroll-behavior: smooth;
	}

	body {
		background: #08111f;
		color: #e6edf7;
		font-family: 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}
</style>
